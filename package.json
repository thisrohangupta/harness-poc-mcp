{
  "name": "harness-mcp-v2",
  "version": "0.5.7",
  "description": "Give AI agents full access to the Harness.io platform — manage pipelines, deployments, feature flags, infrastructure, and 119+ resource types through 10 MCP tools",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "harness-mcp-v2": "build/index.js"
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js stdio",
    "start:http": "node build/index.js http",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js stdio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker build -t harness-mcp-server .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env harness-mcp-server",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "harness",
    "harness-io",
    "ci-cd",
    "model-context-protocol",
    "ai-agent",
    "devops"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/thisrohangupta/harness-mcp-v2.git"
  },
  "bugs": {
    "url": "https://github.com/thisrohangupta/harness-mcp-v2/issues"
  },
  "homepage": "https://github.com/thisrohangupta/harness-mcp-v2#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
